#! /bin/bash

# Q1Libre: fix sudoers permissions immediately (dpkg extracts with Windows perms)
chmod 0440 /etc/sudoers.d/q1libre 2>/dev/null || true

python3 /root/scripts/merge.py

# Q1Libre: Re-enable update_manager after merge.py may have reset it
sed -i 's/^# \[update_manager\]/[update_manager]/' /home/mks/klipper_config/moonraker.conf
sed -i 's/^# channel: dev/channel: dev/' /home/mks/klipper_config/moonraker.conf
sed -i 's/^# refresh_interval: 168/refresh_interval: 168/' /home/mks/klipper_config/moonraker.conf
sed -i 's/^# enable_system_updates: False/enable_system_updates: False/' /home/mks/klipper_config/moonraker.conf
sed -i 's/^# \[update_manager fluidd\]/[update_manager fluidd]/' /home/mks/klipper_config/moonraker.conf
sed -i '/^\[update_manager fluidd\]/,/^$/{s/^# type: web/type: web/; s/^# channel: stable/channel: stable/; s|^# repo: fluidd-core/fluidd|repo: fluidd-core/fluidd|; s|^# path: ~/fluidd|path: ~/fluidd|}' /home/mks/klipper_config/moonraker.conf

# 检查文件
if [ ! -f /etc/bash.bashrc ]; then
    echo "Misiing bash.bashrc file, recovering..."
    cp -fp /root/etc/bash.bashrc /etc/bash.bashrc
fi

# 初始化变量
method_value=0

# 从config.mksini文件中读取method值
while IFS='=' read -r key value; do
    # 去除前后空格
    key=$(echo $key | xargs)
    value=$(echo $value | xargs)

    if [ "$key" = "method" ]; then
        method_value=$value
        break
    fi
done < <(sed -n '/\[app_connection\]/,/\[/p' /home/mks/klipper_config/config.mksini)

# frpc如果不存在则安装
if ! systemctl list-unit-files | grep -qw '^frpc.service'; then
    chmod +x /root/frp/setup_frpc.sh /root/frp/frpc
    bash /root/frp/setup_frpc.sh
fi

# 由于armbian官方的更新 buster似乎不再被支持，因此先注释掉armbian源
sudo sed -i '1s/^/#/' /etc/apt/sources.list.d/armbian.list

#删除旧的时间更新脚本
rm -f /etc/profile.d/time_refresh.sh

#添加日志轮换
mv -f /root/auto_update/auto_update_logrotate /etc/logrotate.d/auto_update_logrotate

# 修改sudo权限
SUDO_FILE="/etc/sudoers.d/mks"

# 重启nginx
sudo systemctl reload nginx


# 使用 echo 和 sudo tee 命令来写入文件内容
echo 'mks ALL=(ALL) ALL, !/usr/sbin/visudo, !/bin/nano /etc/sudoers, !/bin/nano /root/*, !/bin/ls /root, !/bin/cat /etc/sudoers, !/bin/systemctl, !/bin/chmod, NOPASSWD: /usr/bin/psd-overlay-helper, /usr/bin/timedatectl, /usr/bin/apt' | sudo tee $SUDO_FILE > /dev/null
# 设置正确的文件权限
chmod 0440 $SUDO_FILE

if [ ! -f "/home/mks/klipper_config/Adaptive_Mesh.cfg" ]; then
    if [ -f "/root/Adaptive_Mesh.cfg" ]; then
        cp /root/Adaptive_Mesh.cfg /home/mks/klipper_config/ -f
        chmod 644 /home/mks/klipper_config/Adaptive_Mesh.cfg
    fi
fi

#更改ssh登录界面的样式
cp -f /root/10-armbian-header /etc/update-motd.d/10-armbian-header

